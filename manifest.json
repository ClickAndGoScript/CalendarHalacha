{
  "schemaVersion": 1,
  "id": "com.example.otzaria-plugin",
  "name": "Otzaria Plugin",
  "version": "1.0.0",
  "description": "A basic Otzaria plugin template",
  "author": "Plugin Author",
  "homepage": "https://github.com/example/otzaria-plugin",
  "entrypoint": "src/index.html",
  "minAppVersion": "0.9.0",
  "sdkVersion": "1.x",
  "permissions": [
    "ui.feedback",
    "plugin.storage.read",
    "plugin.storage.write"
  ],
  "network": {
    "enabled": false,
    "allowlist": []
  },
  "contributes": {
    "toolTab": {
      "title": "Plugin",
      "order": 100,
      "defaultPinned": false
    }
  }
}
