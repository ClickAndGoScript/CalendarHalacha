{
  "schemaVersion": 1,
  "id": "com.example.hebrew-calendar-demo",
  "name": "לוח שנה עברי - דמו",
  "version": "1.0.0",
  "description": "תוסף דמו שמדגים קריאת נתוני לוח שנה, חיפוש בטקסט ופרסום אירועים חזרה לאוצריא.",
  "author": "Otzaria Plugin Examples",
  "homepage": "https://github.com/Sivan22/otzaria",
  "entrypoint": "index.html",
  "minAppVersion": "0.9.0",
  "sdkVersion": "1.x",
  "permissions": [
    "search.fulltext.read",
    "reader.open",
    "ui.feedback",
    "plugin.storage.read",
    "plugin.storage.write",
    "calendar.read",
    "published_data.write"
  ],
  "network": {
    "enabled": false,
    "allowlist": []
